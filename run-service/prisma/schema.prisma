generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
}

model Run {
    run_id          String    @id @default(uuid())
    run_category_id String    @db.VarChar(36)
    user_id         String    @db.VarChar(36)
    vod_url         String    @db.VarChar(255)
    run_duration    BigInt
    submitted_at    DateTime
    verified_at     DateTime?
    status          String    @db.VarChar(25) @default("PENDING")
    comments        Comment[]

    @@map("runs")
}

model Comment {
    comment_id String   @id @default(uuid())
    run_id     String   @db.VarChar(36)
    user_id    String   @db.VarChar(36)
    comment    String   @db.VarChar(255)
    created_at DateTime
    run        Run      @relation(fields: [run_id], references: [run_id])

    @@map("comments")
}